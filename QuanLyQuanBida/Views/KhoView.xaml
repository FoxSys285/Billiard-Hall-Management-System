<UserControl x:Class="QuanLyQuanBida.Views.KhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyQuanBida.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="734" d:DesignWidth="1150">
    <Grid Background="#FFE9E9E9">
        <Grid.RowDefinitions>
            <RowDefinition Height="68*"/>
            <RowDefinition Height="299*"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="#FFF2EDC2" BorderThickness="1" Margin="30,20,30,0" Background="White" CornerRadius="20,20,20,20">
            <Grid>
                <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="KHO" VerticalAlignment="Center" FontWeight="Bold" FontSize="36" Foreground="Black" Margin="40,0,0,0"/>
                <TextBlock Text="{Binding CurrentAccount.TenNV}" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center" FontWeight="Bold" FontSize="20" Foreground="Black" Margin="797,0,0,0"/>
            </Grid>
        </Border>
        <Border BorderBrush="#FFF2EDC2" BorderThickness="1" Grid.Row="1" Margin="30,20,30,20" Background="White" CornerRadius="20,20,20,20">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Toolbar -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,10,0,10" Grid.Column="0" Grid.ColumnSpan="2">
                    <TextBox x:Name="SearchBox" Width="200" Height="30" Margin="0,0,10,0" VerticalAlignment="Center" Text="" TextChanged="SearchTextBox_TextChanged" />
                    <Button Content="Xuất file" Width="120" Height="30" Margin="0,0,10,0" Command="{Binding ExportProductsCommand}"/>
                    <Button Content="Xóa" Width="120" Height="30" Margin="0,0,10,0" Command="{Binding DeleteProductCommand}"/>
                    <Button Content="Phiếu nhập mới" Width="140" Height="30" Command="{Binding NewKhoCommand}"/>
                </StackPanel>

                <!-- Left DataGrid - Kho (Inventory) -->
                <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="DANH SÁCH KHO" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredSanPham}" AutoGenerateColumns="False" SelectedItem="{Binding SelectedSanPhamKho, Mode=TwoWay}" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="*" Header="Tên sản phẩm" Binding="{Binding TenSanPham}" />
                            <DataGridTextColumn Width="100" Header="Tồn kho" Binding="{Binding TonDu}" />
                            <DataGridTextColumn Width="80" Header="Đơn vị" Binding="{Binding DonVi}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Right DataGrid - PhieuNhap (Receipt) -->
                <Grid Grid.Row="1" Grid.Column="1" Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="PHIẾU NHẬP" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding DsPhieuNhap}" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="100" Header="Mã PN" Binding="{Binding MaPN}" />
                            <DataGridTextColumn Width="100" Header="Mã SP" Binding="{Binding MaSP}" />
                            <DataGridTextColumn Width="80" Header="Số lượng" Binding="{Binding SoLuong}" />
                            <DataGridTextColumn Width="90" Header="Giá nhập" Binding="{Binding GiaNhap, StringFormat=N0}" />
                            <DataGridTextColumn Width="*" Header="Ngày nhập" Binding="{Binding NgayNhap, StringFormat=dd/MM/yyyy}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
