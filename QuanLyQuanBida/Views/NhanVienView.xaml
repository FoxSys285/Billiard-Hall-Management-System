                        <TextBlock HorizontalAlignment="Left" Margin="173,280,0,0" TextWrapping="Wrap" Text="Ngày vào làm" VerticalAlignment="Top" FontWeight="Bold" Foreground="#FF70B875"/>

                        <TextBlock HorizontalAlignment="Left" Margin="20,360,0,0" TextWrapping="Wrap" Text="Tài khoản" VerticalAlignment="Top" FontWeight="Bold" Foreground="#FF70B875"/>
                        <TextBlock HorizontalAlignment="Left" Margin="168,360,0,0" TextWrapping="Wrap" Text="Mật khẩu" VerticalAlignment="Top" FontWeight="Bold" Foreground="#FF70B875"/>

                        <Button Command="{Binding EditNVCommand}"  Content="Sửa" HorizontalAlignment="Center" Width="200" Margin="0,460,0,0" VerticalAlignment="Top" FontSize="14" FontWeight="Bold">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="btnBorder" 
                    Background="{TemplateBinding Background}" 
                    BorderBrush="{TemplateBinding BorderBrush}" 
                    BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="btnBorder" Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                                    <GradientStop Color="#FFD3D3D3" Offset="0"/>
                                                                    <GradientStop Color="#FFA9A9A9" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="Foreground" Value="DarkGray"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="BorderBrush" Value="White"/>
                                                    </Trigger>

                                                    <Trigger Property="IsEnabled" Value="True">
                                                        <Setter TargetName="btnBorder" Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                                    <GradientStop Color="#FF20800E" Offset="0"/>
                                                                    <GradientStop Color="#FF33A01E" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>

                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="btnBorder" Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBox Text="{Binding EditingNV.MaNV}" IsReadOnly="True" HorizontalAlignment="Left" Margin="20,60,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="102" Foreground="#FF8FA698" FontSize="14" BorderBrush="#FF7FBA85" Background="{x:Null}" BorderThickness="0,0,0,1"/>
                        <TextBox Text="{Binding EditingNV.TenNV}" HorizontalAlignment="Left" Margin="135,60,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="173" Foreground="#FF2E583E" FontSize="14" BorderBrush="#FF239D2F" Background="{x:Null}" BorderThickness="0,0,0,1"/>
                        <ComboBox ItemsSource="{Binding DanhSachChucVu}" SelectedItem="{Binding EditingNV.ChucVu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Margin="20,140,0,0" VerticalAlignment="Top" Width="102" Foreground="#FF2E583E" FontSize="14" BorderThickness="0,0,0,0" Background="{x:Null}"/>
                        <TextBox Text="{Binding EditingNV.DiaChi}" HorizontalAlignment="Left" Margin="20,220,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="125" Foreground="#FF2E583E" FontSize="14" BorderBrush="#FF239D2F" Background="{x:Null}" BorderThickness="0,0,0,1"/>
                        <TextBox Text="{Binding EditingNV.SDT}" HorizontalAlignment="Left" Margin="159,220,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="149" Foreground="#FF2E583E" FontSize="14" BorderBrush="#FF239D2F" Background="{x:Null}" BorderThickness="0,0,0,1"/>
                        <DatePicker SelectedDate="{Binding EditingNV.NgaySinh}" HorizontalAlignment="Left" Margin="20,300,0,0" VerticalAlignment="Top" Width="129" Background="#FFF4F4F4" BorderBrush="{x:Null}" Foreground="#FF2E583E" FontSize="14"/>
                        <DatePicker SelectedDate="{Binding EditingNV.NgayVL}" HorizontalAlignment="Left" Margin="171,300,0,0" VerticalAlignment="Top" Width="137" BorderBrush="{x:Null}" Foreground="#FF2E583E" FontSize="14"/>
                        <TextBox Text="{Binding EditingNV.TaiKhoan}" HorizontalAlignment="Left" Margin="20,380,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="134" Foreground="#FF2E583E" FontSize="14" BorderBrush="#FF239D2F" Background="{x:Null}" BorderThickness="0,0,0,1"/>
                        <TextBox Text="{Binding EditingNV.MatKhau}" HorizontalAlignment="Left" Margin="168,380,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="140" Foreground="#FF2E583E" FontSize="14" BorderBrush="#FF239D2F" Background="{x:Null}" BorderThickness="0,0,0,1"/>
                    </Grid>
                </Border>
                <TextBlock HorizontalAlignment="Left" Margin="10,69,0,0" TextWrapping="Wrap" Text="Tìm kiếm:" VerticalAlignment="Top" FontWeight="Bold" Foreground="#FF3C6A25" FontSize="14"/>


            </Grid>
        </Border>
        <Border Visibility="{Binding VisibileAddNV}" 
                Panel.ZIndex="100"
                IsEnabled="True"
                BorderBrush="#FF2E6A3C"
                BorderThickness="3"
                Margin="331,78,331,130"
                Background="White"
                CornerRadius="10" Grid.RowSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="11*"/>
                </Grid.RowDefinitions>
                <Border BorderBrush="White" BorderThickness="1" Margin="10,10,10,10" Grid.Row="0" Background="#FFEDEDED" CornerRadius="10,10,10,10">
                    <Grid>
                        <TextBlock HorizontalAlignment="Left" Margin="20,0,0,0" TextWrapping="Wrap" Text="NHÂN VIÊN MỚI" VerticalAlignment="Center" FontWeight="Bold" FontSize="16" Foreground="#FF28893C"/>
                        <Button Command="{Binding ExitThemNVCommand}" Content="❌" HorizontalAlignment="Left" Margin="420,0,0,0" VerticalAlignment="Center" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="#FF28893C"/>
                    </Grid>
                </Border>
                <Border BorderBrush="White" BorderThickness="1" Margin="10,10,10,10" Grid.Row="1" Background="#FFEDEDED" CornerRadius="10,10,10,10">
                    <Grid>
                        <TextBlock HorizontalAlignment="Left" Margin="29,45,0,0" TextWrapping="Wrap" Text="Mã" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Center" Margin="0,45,0,0" TextWrapping="Wrap" Text="Họ và tên" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Left" Margin="76,182,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Left" Margin="348,190,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top"/>
                        <TextBox HorizontalAlignment="Left" Margin="29,66,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
                        <TextBox HorizontalAlignment="Left" Margin="204,66,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
                    </Grid>
                </Border>
                <Border BorderBrush="White" BorderThickness="1" Margin="10,10,10,10" Grid.Row="1" Background="#FFEDEDED" CornerRadius="10,10,10,10">
                    <Grid>
                        <TextBlock HorizontalAlignment="Left" Margin="30,40,0,0" TextWrapping="Wrap" Text="Mã" VerticalAlignment="Top" Foreground="#FF28893C"/>
                        <TextBlock HorizontalAlignment="Left" Margin="255,40,0,0" TextWrapping="Wrap" Text="Họ và tên" VerticalAlignment="Top" Foreground="#FF28893C"/>
                        <TextBlock HorizontalAlignment="Left" Margin="30,100,0,0" TextWrapping="Wrap" Text="Chức vụ" VerticalAlignment="Top" Foreground="#FF28893C"/>
                        <TextBlock HorizontalAlignment="Left" Margin="30,160,0,0" TextWrapping="Wrap" Text="Địa chỉ" VerticalAlignment="Top" Foreground="#FF28893C"/>
                        <TextBlock HorizontalAlignment="Left" Margin="256,160,0,0" Text="Số điện thoại" VerticalAlignment="Top" Foreground="#FF28893C"/>
                        <TextBlock HorizontalAlignment="Left" Margin="30,220,0,0" TextWrapping="Wrap" Text="Ngày sinh" VerticalAlignment="Top" Foreground="#FF28893C"/>
                        <TextBlock HorizontalAlignment="Left" Margin="255,220,0,0" TextWrapping="Wrap" Text="Ngày vào làm" VerticalAlignment="Top" Foreground="#FF28893C"/>
                        <TextBlock HorizontalAlignment="Left" Margin="30,280,0,0" TextWrapping="Wrap" Text="Tài khoản" VerticalAlignment="Top" Foreground="#FF28893C"/>
                        <TextBlock HorizontalAlignment="Left" Margin="255,280,0,0" TextWrapping="Wrap" Text="Mật khẩu" VerticalAlignment="Top" Foreground="#FF28893C"/>
                        <Button Content="Thêm nhân viên" HorizontalAlignment="Left" Margin="30,358,0,0" VerticalAlignment="Top" Foreground="White" FontSize="14" Width="407" FontWeight="Bold" Height="35">
                            <Button.Background>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="#FF1CA11F" Offset="0.008"/>
                                    <GradientStop Color="#FF8DE38F" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <TextBox HorizontalAlignment="Left" Margin="30,60,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="170" Foreground="#FF28893C" FontSize="14"/>
                        <TextBox Text="{Binding InputTenNV}" HorizontalAlignment="Left" Margin="255,60,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="182" RenderTransformOrigin="0.22,-0.546" Foreground="#FF28893C" FontSize="14"/>
                        <TextBox Text="{Binding InputDiaChi}" HorizontalAlignment="Left" Margin="30,180,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="170" Foreground="#FF28893C" FontSize="14"/>
                        <TextBox Text="{Binding InputSDT}" HorizontalAlignment="Left" Margin="256,180,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="182" Foreground="#FF28893C" FontSize="14"/>
                        <TextBox Text="{Binding InputNewTK}" HorizontalAlignment="Left" Margin="30,300,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="170" Foreground="#FF28893C" FontSize="14"/>
                        <TextBox Text="{Binding InputNewMK}" HorizontalAlignment="Left" Margin="255,300,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="182" Foreground="#FF28893C" FontSize="14"/>
                        <DatePicker SelectedDate="{Binding InputNgaySinh, Mode=TwoWay}" HorizontalAlignment="Left" Margin="30,240,0,0" VerticalAlignment="Top" Background="{x:Null}" FontSize="14" Width="170"/>
                        <DatePicker SelectedDate="{Binding InputNgayVL, Mode=TwoWay}" HorizontalAlignment="Left" Margin="255,240,0,0" VerticalAlignment="Top" FontSize="14" Width="182"/>
                        <ComboBox Text="{Binding InputChucVu}" HorizontalAlignment="Left" Margin="30,120,0,0" VerticalAlignment="Top" Width="170" Foreground="#FF28893C" FontSize="14"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>
        <Border Visibility="{Binding VisibileAddNV}"
        Panel.ZIndex="100"
        IsEnabled="True"
        BorderBrush="#FF2E6A3C"
        BorderThickness="3"
        Margin="101,78,104,130"
        Background="White"
        CornerRadius="10" Grid.RowSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="11*"/>
                </Grid.RowDefinitions>
                <Border BorderBrush="White" BorderThickness="1" Margin="10,10,10,10" Grid.Row="0" Background="#FFEDEDED" CornerRadius="10,10,10,10">
                    <Grid>
                        <TextBlock HorizontalAlignment="Left" Margin="20,0,0,0" TextWrapping="Wrap" Text="CHẤM CÔNG" VerticalAlignment="Center" FontWeight="Bold" FontSize="16" Foreground="#FF28893C"/>
                        <Button Command="{Binding ExitThemNVCommand}" Content="❌" HorizontalAlignment="Left" Margin="865,0,0,0" VerticalAlignment="Center" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="#FF28893C"/>
                    </Grid>
                </Border>
                <Border BorderBrush="White" BorderThickness="1" Margin="10,10,10,10" Grid.Row="1" Background="#FFEDEDED" CornerRadius="10,10,10,10">
                    <Grid>
                        <TextBlock HorizontalAlignment="Left" Margin="29,45,0,0" TextWrapping="Wrap" Text="Mã" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Center" Margin="0,45,0,0" TextWrapping="Wrap" Text="Họ và tên" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Left" Margin="76,182,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Left" Margin="348,190,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top"/>
                        <TextBox HorizontalAlignment="Left" Margin="29,66,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
                        <TextBox HorizontalAlignment="Left" Margin="204,66,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
                    </Grid>
                </Border>
                <Border BorderBrush="White" BorderThickness="1" Margin="10,10,10,10" Grid.Row="1" Background="#FFEDEDED" CornerRadius="10,10,10,10">
                    <Grid>
                        
                        <DataGrid  SelectionMode="Single" IsReadOnly="True" AutoGenerateColumns="False" CanUserResizeColumns="False" CanUserResizeRows="False" Margin="10,138,416,138" Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Họ tên" Width="150">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Chức vụ" Width="150">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Số giờ làm việc" Width="*">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <ListBox d:ItemsSource="{d:SampleData ItemCount=10}" Margin="534,77,10,69" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Width="100" Margin="10" Text="12/02/2005"/>
                                        <TextBlock Width="100" Margin="10" Text="9 giờ"/>
                                        <TextBlock Width="100" Margin="10" Text="Đã chấm công"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock HorizontalAlignment="Left" Margin="658,35,0,0" TextWrapping="Wrap" Text="Bảng chấm công"  VerticalAlignment="Top" FontWeight="Bold" FontSize="16" Foreground="#FF28893C"/>
                        <Button Content="Chấm công" HorizontalAlignment="Left" Margin="648,371,0,0" VerticalAlignment="Top" Width="146"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <Grid Grid.RowSpan="2" 
          Background="#66000000" 
          Panel.ZIndex="99"
          Visibility="{Binding VisibileAddNV}">
        </Grid>
    </Grid>
</UserControl>
