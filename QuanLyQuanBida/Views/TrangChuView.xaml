<UserControl x:Class="QuanLyQuanBida.Views.TrangChuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:QuanLyQuanBida.Converters"
             mc:Ignorable="d" d:DesignHeight="734" d:DesignWidth="1150"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="RoundedAccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="MinHeight" Value="140"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="14" SnapsToDevicePixels="True" RenderTransformOrigin="0.5,0.5" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#66000000" BlurRadius="14" ShadowDepth="4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.95"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedAccentButton}">
            <Setter Property="Background" Value="#2D5A42"/>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource RoundedAccentButton}">
            <Setter Property="Background" Value="#E67E22"/>
        </Style>
    </UserControl.Resources>
    <Grid Background="#FFF3F5F6" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto" MinHeight="90"/>
            <!-- Quick metrics -->
            <RowDefinition/>
            <!-- Middle tabs -->
            <RowDefinition Height="332.117"/>
            <!-- Footer: chart + top customers -->
        </Grid.RowDefinitions>

        <!-- Header (styled like other section titles) -->
        <Border Grid.Row="0" BorderBrush="#FFF2EDC2" BorderThickness="1" Margin="20,10,20,10" Background="White" CornerRadius="20,20,20,20">
            <Grid>
                <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="TRANG CHỦ" VerticalAlignment="Center" FontWeight="Bold" FontSize="36" Foreground="Black" Margin="40,0,0,0"/>
                <TextBlock Text="{Binding CurrentAccount.TenNV}" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center" FontWeight="Bold" FontSize="20" Foreground="Black" Margin="797,0,0,0"/>
            </Grid>
        </Border>

        <!-- Quick metrics -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0,20,10">
            <Border Background="White" CornerRadius="10" Padding="16" Width="250" BorderBrush="#FFE8E8E8" BorderThickness="1" Height="80">
                <StackPanel>
                    <TextBlock Text="Tổng số bàn" Foreground="#888"/>
                    <TextBlock Text="{Binding DsBan.Count}" FontSize="28" FontWeight="Bold" Foreground="#2D5A42"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="16" Width="250" BorderBrush="#FFE8E8E8" BorderThickness="1" Height="80">
                <StackPanel>
                    <TextBlock Text="Bàn đang chơi" Foreground="#888"/>
                    <TextBlock Text="{Binding SoBanDangHoatDong}" FontSize="28" FontWeight="Bold" Foreground="#D9534F"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="16" Width="300" BorderBrush="#FFE8E8E8" BorderThickness="1" Height="80">
                <StackPanel>
                    <TextBlock Text="Doanh thu hôm nay" Foreground="#888"/>
                    <TextBlock Text="{Binding TongDoanhThuHomNay, StringFormat={}{0:N0} VND}" FontSize="28" FontWeight="Bold" Foreground="#E67E22"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="16" Width="290" BorderBrush="#FFE8E8E8" BorderThickness="1" Height="80">
                <StackPanel>
                    <TextBlock Text="Số hóa đơn hôm nay" Foreground="#888"/>
                    <TextBlock Text="{Binding SoHoaDonHomNay}" FontSize="28" FontWeight="Bold" Foreground="#2D5A42"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Middle: two big buttons to navigate to Ban or Menu -->
        <Border Grid.Row="2" Margin="20,0,20,12" Background="White" CornerRadius="12" BorderBrush="#FFE8E8E8" BorderThickness="1" Padding="20" MinHeight="200">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Margin="8" Command="{Binding SwitchViewCommand}" CommandParameter="Ban"
                        Style="{StaticResource PrimaryButton}" BorderThickness="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="TÌNH TRẠNG BÀN"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Margin="8" Command="{Binding SwitchViewCommand}" CommandParameter="Menu"
                        Style="{StaticResource AccentButton}" BorderThickness="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="MENU" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Footer: Revenue chart + Top 5 customers -->
        <Border Grid.Row="3" Margin="20,0,20,20" Background="White" CornerRadius="12" BorderBrush="#FFE8E8E8" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Real simple bar chart for revenue by table -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Biểu đồ doanh thu" FontWeight="Bold" FontSize="16" Margin="6"/>
                    <ScrollViewer Margin="6" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DsThongKeBan}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6" Width="120" HorizontalAlignment="Center">
                                        <Border Height="140" Background="#FFF" CornerRadius="6" Padding="6" BorderBrush="#EEE" BorderThickness="1">
                                            <StackPanel VerticalAlignment="Bottom" Height="120">
                                                <Grid VerticalAlignment="Bottom">
                                                    <Rectangle Width="40" HorizontalAlignment="Center" Fill="#2D5A42" RadiusX="4" RadiusY="4">
                                                        <Rectangle.Height>
                                                            <MultiBinding Converter="{StaticResource ValueToHeightConverter}" ConverterParameter="120">
                                                                <Binding Path="TongTien"/>
                                                                <!-- bind to ViewModel.MaxTongTienBan via DataContext on the UserControl -->
                                                                <Binding Path="DataContext.MaxTongTienBan" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </Rectangle.Height>
                                                    </Rectangle>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="{Binding TenBan}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} VND}" FontSize="12" Foreground="#666" TextAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- Top 10 customers -->
                <Grid Grid.Column="1" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Top 10 khách hàng" FontWeight="Bold" FontSize="16" Margin="6"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,6,0,0">
                        <ItemsControl ItemsSource="{Binding DsTopKhachHang}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Margin="4" Background="#FBFBFB" BorderBrush="#EEE" BorderThickness="1" CornerRadius="6">
                                        <DockPanel>
                                            <TextBlock FontWeight="Bold" Width="30">
                                                <Run Text="{Binding ViTri}" />
                                                <Run Text="." />
                                            </TextBlock>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenKhachHang}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding SoDienThoai}" Foreground="#777" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DiemTichLuy}" DockPanel.Dock="Right" HorizontalAlignment="Right" FontWeight="Bold" Margin="8,0,0,0"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
