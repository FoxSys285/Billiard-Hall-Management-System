<UserControl x:Class="QuanLyQuanBida.Views.TrangChuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:QuanLyQuanBida.Converters"
             mc:Ignorable="d" d:DesignHeight="734" d:DesignWidth="1150"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <conv:ValueToHeightConverter x:Key="ValueToHeightConverter" />
    </UserControl.Resources>
    <Grid Background="#FFF3F5F6" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto" MinHeight="90"/>
            <!-- Quick metrics -->
            <RowDefinition/>
            <!-- Middle tabs -->
            <RowDefinition Height="250"/>
            <!-- Footer: chart + top customers -->
        </Grid.RowDefinitions>

        <!-- Header (styled like other section titles) -->
        <Border Grid.Row="0" BorderBrush="#FFF2EDC2" BorderThickness="1" Margin="20,10,20,10" Background="White" CornerRadius="20">
            <Grid>
                <TextBlock HorizontalAlignment="Left" Text="TRANG CHỦ" VerticalAlignment="Center" FontWeight="Bold" FontSize="36" Foreground="Black" Margin="40,0,0,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,40,0">
                    <TextBlock Text="{Binding CurrentAccount.TenNV}" FontWeight="Bold" FontSize="20" Foreground="Black" VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <Button Content="❌" Background="{x:Null}" FontWeight="Bold" FontSize="30" Foreground="Black" BorderBrush="{x:Null}" Click="Button_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Quick metrics -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0,20,10">
            <Border Background="White" CornerRadius="10" Padding="16" Width="250" BorderBrush="#FFE8E8E8" BorderThickness="1" Height="80">
                <StackPanel>
                    <TextBlock Text="Tổng số bàn" Foreground="#888"/>
                    <TextBlock Text="{Binding DsBan.Count}" FontSize="28" FontWeight="Bold" Foreground="#2D5A42"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="16" Width="250" BorderBrush="#FFE8E8E8" BorderThickness="1" Height="80">
                <StackPanel>
                    <TextBlock Text="Bàn đang chơi" Foreground="#888"/>
                    <TextBlock Text="{Binding SoBanDangHoatDong}" FontSize="28" FontWeight="Bold" Foreground="#D9534F"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="16" Width="300" BorderBrush="#FFE8E8E8" BorderThickness="1" Height="80">
                <StackPanel>
                    <TextBlock Text="Doanh thu hôm nay" Foreground="#888"/>
                    <TextBlock Text="{Binding TongDoanhThu, StringFormat={}{0:N0} VND}" FontSize="28" FontWeight="Bold" Foreground="#E67E22"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="16" Width="290" BorderBrush="#FFE8E8E8" BorderThickness="1" Height="80">
                <StackPanel>
                    <TextBlock Text="Số hóa đơn hôm nay" Foreground="#888"/>
                    <TextBlock Text="{Binding SoHoaDonDaThanhToan}" FontSize="28" FontWeight="Bold" Foreground="#2D5A42"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Middle: two big buttons to navigate to Ban or Menu -->
        <Border Grid.Row="2" Margin="20,0,20,12" Background="White" CornerRadius="12" BorderBrush="#FFE8E8E8" BorderThickness="1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Margin="8" Padding="20" Command="{Binding SwitchViewCommand}" CommandParameter="Ban"
                        Background="#2D5A42" Foreground="White" FontSize="20" FontWeight="Bold" BorderThickness="0" Height="160" Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="TÌNH TRẠNG BÀN"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Margin="8" Padding="20" Command="{Binding SwitchViewCommand}" CommandParameter="Menu"
                        Background="#E67E22" Foreground="White" FontSize="20" FontWeight="Bold" BorderThickness="0" Height="160" Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="MENU" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Footer: Revenue chart + Top 5 customers -->
        <Border Grid.Row="3" Margin="20,0,20,20" Background="White" CornerRadius="12" BorderBrush="#FFE8E8E8" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Real simple bar chart for revenue by table -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Biểu đồ doanh thu" FontWeight="Bold" FontSize="16" Margin="6"/>
                    <ScrollViewer Margin="6" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DsThongKeBan}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6" Width="120" HorizontalAlignment="Center">
                                        <Border Height="140" Background="#FFF" CornerRadius="6" Padding="6" BorderBrush="#EEE" BorderThickness="1">
                                            <StackPanel VerticalAlignment="Bottom" Height="120">
                                                <Grid VerticalAlignment="Bottom">
                                                    <Rectangle Width="40" HorizontalAlignment="Center" Fill="#2D5A42" RadiusX="4" RadiusY="4">
                                                        <Rectangle.Height>
                                                            <MultiBinding Converter="{StaticResource ValueToHeightConverter}" ConverterParameter="120">
                                                                <Binding Path="TongTien"/>
                                                                <!-- bind to ViewModel.MaxTongTienBan via DataContext on the UserControl -->
                                                                <Binding Path="DataContext.MaxTongTienBan" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </Rectangle.Height>
                                                    </Rectangle>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="{Binding TenBan}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} VND}" FontSize="12" Foreground="#666" TextAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- Top 5 customers -->
                <StackPanel Grid.Column="1" Margin="12">
                    <TextBlock Text="Top 5 khách hàng" FontWeight="Bold" FontSize="16" Margin="6"/>
                    <ItemsControl ItemsSource="{Binding DsTopKhachHang}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="4" Background="#FBFBFB" BorderBrush="#EEE" BorderThickness="1" CornerRadius="6">
                                    <DockPanel>
                                        <TextBlock FontWeight="Bold" Width="30">
                                            <Run Text="{Binding ViTri}" />
                                            <Run Text="." />
                                        </TextBlock>
                                        <StackPanel>
                                            <TextBlock Text="{Binding TenKhachHang}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SoDienThoai}" Foreground="#777" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DiemTichLuy}" DockPanel.Dock="Right" HorizontalAlignment="Right" FontWeight="Bold" Margin="8,0,0,0"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
