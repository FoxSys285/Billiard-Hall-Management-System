<UserControl x:Class="QuanLyQuanBida.Views.LichSuHoaDonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyQuanBida.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="734" d:DesignWidth="1150">
    <Grid Background="#FFE9E9E9">
        <Grid.RowDefinitions>
            <RowDefinition Height="68*"/>
            <RowDefinition Height="299*"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="#FFF2EDC2" BorderThickness="1" Margin="30,20,30,0" Background="White" CornerRadius="20,20,20,20">
            <Grid>
                <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="LỊCH SỬ HÓA ĐƠN" VerticalAlignment="Center" FontWeight="Bold" FontSize="36" Foreground="Black" Margin="40,0,0,0"/>
                <TextBlock Text="{Binding CurrentAccount.TenNV}" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center" FontWeight="Bold" FontSize="20" Foreground="Black" Margin="797,0,0,0"/>
            </Grid>
        </Border>

        <Border BorderBrush="#FFF2EDC2" BorderThickness="1" Grid.Row="1" Margin="30,20,30,20" Background="White" CornerRadius="20">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Grid.Row="0" Margin="10">
                    <TextBlock Text="Lọc dữ liệu:" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="Bold" />
                    <StackPanel Orientation="Vertical" Margin="0,0,15,0">
                        <TextBlock FontSize="11" Text="Từ ngày" Foreground="Gray" />
                        <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay}" Width="130" />
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Margin="0,0,15,0">
                        <TextBlock FontSize="11" Text="Đến ngày" Foreground="Gray" />
                        <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay}" Width="130" />
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Margin="0,0,15,0">
                        <TextBlock FontSize="11" Text="Nhân viên lập" Foreground="Gray" />
                        <ComboBox ItemsSource="{Binding DsNhanVien}" SelectedItem="{Binding SelectedNhanVien}" DisplayMemberPath="TenNV" Width="160" />
                    </StackPanel>
                    <Button Content="Lọc danh sách" Command="{Binding LocHoaDonCommand}" Margin="10,15,0,0" Padding="15,5" Background="#2E7D32" Foreground="White" Cursor="Hand" />
                    <Button Content="Xuất Excel" Command="{Binding XuatExcelHoaDonCommand}" Margin="10,15,0,0" Padding="15,5" Background="#1565C0" Foreground="White" Cursor="Hand" />
                    <Button Content="Xuất báo cáo" Command="{Binding XuatBaoCaoHoaDonCommand}" Margin="10,15,0,0" Padding="15,5" Background="#FF8F00" Foreground="White" Cursor="Hand" />
                    <Button Content="Tất cả" Command="{Binding ShowAllHoaDonCommand}" Margin="10,15,0,0" Padding="15,5" Background="#FF00BEFF" Foreground="White" Cursor="Hand" /> 
                </StackPanel>

                <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredHoaDon}" SelectedItem="{Binding SelectedHoaDon, Mode=TwoWay}" AutoGenerateColumns="False" CanUserAddRows="False" 
                          IsReadOnly="True" GridLinesVisibility="Horizontal" SelectionUnit="FullRow" BorderThickness="0.5" BorderBrush="LightGray">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã HD" Binding="{Binding MaHoaDon}" Width="80" />
                        <DataGridTextColumn Header="Khách hàng" Binding="{Binding KhachHang.TenKhachHang}" Width="180" />
                        <DataGridTextColumn Header="Bàn" Binding="{Binding MaBan}" Width="70" />
                        <DataGridTextColumn Header="Ngày lập" Binding="{Binding NgayHoaDon, StringFormat=\{0:dd/MM/yyyy\}}" Width="120" />
                        <DataGridTextColumn Header="Giờ vào" Binding="{Binding GioVaoHoaDon, StringFormat=\{0:hh\\:mm\}}" Width="90" />
                        <DataGridTextColumn Header="Giờ ra" Binding="{Binding GioRaHoaDon, StringFormat=\{0:hh\\:mm\}}" Width="90" />
                        <DataGridTextColumn Header="Thành tiền" Binding="{Binding TongTienHoaDon, StringFormat=N0}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,10,0" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Nhân viên" Binding="{Binding NhanVien.TenNV}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>