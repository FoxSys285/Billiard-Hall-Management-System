<UserControl x:Class="QuanLyQuanBida.Views.BanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:QuanLyQuanBida.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="734" d:DesignWidth="1150"
             d:DataContext="{d:DesignInstance local:MainViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>

        <!-- Màu card bàn: xanh lá = trống, xanh dương = có khách -->
        <Style x:Key="TrangThaiColorStyle" TargetType="Border">
            <Setter Property="Background"      Value="#047b5c"/>
            <Setter Property="BorderBrush"     Value="#333"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Style.Triggers>
                <!-- Có khách → xanh dương -->
                <DataTrigger Binding="{Binding TrangThaiBan}" Value="True">
                    <Setter Property="Background" Value="#1565C0"/>
                </DataTrigger>
                <!-- Đang chọn → viền cam -->
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter Property="BorderBrush"     Value="#FF9800"/>
                    <Setter Property="BorderThickness" Value="4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Template bàn lỗ -->
        <DataTemplate x:Key="BanLoTemplate">
            <Border Width="140" Height="90" Style="{StaticResource TrangThaiColorStyle}" CornerRadius="8" Margin="10">
                <Grid>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Left"   VerticalAlignment="Top"    Margin="-2"/>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Top"    Margin="-2"/>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Right"  VerticalAlignment="Top"    Margin="-2"/>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Left"   VerticalAlignment="Bottom" Margin="-2"/>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="-2"/>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Right"  VerticalAlignment="Bottom" Margin="-2"/>
                    <TextBlock Text="{Binding TenBan}" Foreground="White" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template bàn phẳng -->
        <DataTemplate x:Key="BanPhangTemplate">
            <Border Width="140" Height="90" Style="{StaticResource TrangThaiColorStyle}" CornerRadius="8" Margin="10">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,5">
                        <Ellipse Fill="White"  Width="10" Height="10" Margin="2"/>
                        <Ellipse Fill="Yellow" Width="10" Height="10" Margin="2"/>
                        <Ellipse Fill="Red"    Width="10" Height="10" Margin="2"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TenBan}" Foreground="White" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Style nút trong overlay -->
        <Style x:Key="OverlayBtnStyle" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="#FFE9E9E9">
        <Grid.RowDefinitions>
            <RowDefinition Height="68*"/>
            <RowDefinition Height="299*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border BorderBrush="#FFF2EDC2" BorderThickness="1" Margin="30,20,30,0"
                Background="White" CornerRadius="20">
            <Grid>
                <TextBlock Text="BÀN" HorizontalAlignment="Left" VerticalAlignment="Center"
                           FontWeight="Bold" FontSize="36" Foreground="Black" Margin="40,0,0,0"/>
                <TextBlock Text="{Binding CurrentAccount.TenNV}" HorizontalAlignment="Left"
                           VerticalAlignment="Center" FontWeight="Bold" FontSize="20"
                           Foreground="Black" Margin="797,0,0,0"/>
                <Button Content="❌" Background="{x:Null}" FontWeight="Bold" FontSize="40"
                        Foreground="Black" Margin="985,26,44,33"
                        BorderBrush="{x:Null}" Click="Button_Click"/>
            </Grid>
        </Border>

        <!-- ===== NỘI DUNG ===== -->
        <Border BorderBrush="#FFF2EDC2" BorderThickness="1" Grid.Row="1"
                Margin="30,20,30,20" Background="White" CornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== CỘT TRÁI: DANH SÁCH BÀN ===== -->
                <Grid Grid.Column="0" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Lọc bàn — bind vào DsLocBan + FilterBan -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Lọc bàn: " VerticalAlignment="Center" FontWeight="Bold"/>
                        <ComboBox Width="150" Margin="10,0,0,0"
                                  ItemsSource="{Binding DsLocBan}"
                                  SelectedItem="{Binding FilterBan, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Danh sách bàn đã lọc — dùng DsBanHienThi -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding DsBanHienThi}"
                                 SelectedItem="{Binding SelectedBan, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding}">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding KieuBan}" Value="BanLoTemple">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource BanLoTemplate}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding KieuBan}" Value="BanPhangTemple">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource BanPhangTemplate}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>

                <Rectangle Grid.Column="0" HorizontalAlignment="Right" Width="1" Fill="Black" Margin="0,10,0,10"/>

                <!-- ===== CỘT PHẢI: CHI TIẾT HÓA ĐƠN ===== -->
                <Grid Grid.Column="1" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Thông tin bàn đang chọn -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="CHI TIẾT HÓA ĐƠN" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <!-- Tên bàn -->
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Tên bàn: " FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedBan.TenBan}" Margin="5,0,0,0"
                                       FontWeight="Bold" Foreground="Blue"/>
                        </StackPanel>

                        <!-- Trạng thái: bind TrangThaiHienTai → "Trống" / "Có khách" -->
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Trạng thái: " FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TrangThaiHienTai}" Margin="5,0,0,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#2e7d32"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedBan.TrangThaiBan}" Value="True">
                                                <Setter Property="Foreground" Value="OrangeRed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Giờ chơi: chỉ hiện khi bàn có khách (TrangThaiBan=True) -->
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedBan.TrangThaiBan}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Giờ chơi: " FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding GioVaoBan}" Foreground="Gray" Margin="5,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Danh sách món đang có trên bàn — bind DsMonAnCuaBan -->
                    <ListView Grid.Row="1" Margin="0,10,0,10"
                              ItemsSource="{Binding DsMonAnCuaBan}"
                              BorderBrush="#FFCCCCCC" BorderThickness="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Tên món"    Width="140"
                                                DisplayMemberBinding="{Binding TenMon}"/>
                                <GridViewColumn Header="Số lượng"   Width="70"
                                                DisplayMemberBinding="{Binding SoLuong}"/>
                                <GridViewColumn Header="Thành tiền" Width="95">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock TextAlignment="Right"
                                                       Text="{Binding ThanhTien, StringFormat={}{0:N0} đ}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Tổng tiền + 3 nút -->
                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                            <TextBlock Text="Tổng tiền: " FontWeight="Bold" FontSize="16"/>
                            <TextBlock FontWeight="Bold" FontSize="16" Foreground="Red" Margin="5,0,10,0"
                                       Text="{Binding TongTienHienTai, StringFormat={}{0:N0} VNĐ}"/>
                        </StackPanel>
                        <Button Content="Đặt Bàn"     Height="35" Margin="0,0,0,5"
                                Background="Green" Foreground="White" FontWeight="Bold"
                                Command="{Binding DatBanCommand}"/>
                        <Button Content="Xuất Hóa Đơn" Height="35" Margin="0,0,0,5"
                                Background="IndianRed" Foreground="White" FontWeight="Bold"
                                Command="{Binding XuatHoaDonCommand}"/>
                        <Button Content="Thanh toán"  Height="35"
                                Background="OrangeRed" Foreground="White" FontWeight="Bold"
                                Command="{Binding ThanhToanCommand}"/>
                    </StackPanel>
                </Grid>

                <!-- =================================================
                     OVERLAY ĐẶT BÀN
                     Hiện khi IsShowDatBanOverlay = True
                     ================================================= -->
                <Grid Grid.ColumnSpan="2" Panel.ZIndex="99" Background="#88000000">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsShowDatBanOverlay}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Border Background="White" CornerRadius="16"
                            Width="940" MaxHeight="590"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="52"/>
                                <!-- Header xanh -->
                                <RowDefinition Height="*"/>
                                <!-- TabControl -->
                                <RowDefinition Height="56"/>
                                <!-- Footer -->
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0" Background="#1565C0" CornerRadius="16,16,0,0">
                                <Grid Margin="16,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="🎱  ĐẶT BÀN — " Foreground="White" FontWeight="Bold" FontSize="17"/>
                                        <TextBlock Text="{Binding SelectedBan.TenBan}"
                                                   Foreground="#FFD700" FontWeight="Bold" FontSize="17"/>
                                    </StackPanel>
                                    <Button Content="✕" HorizontalAlignment="Right"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="White" FontSize="20" FontWeight="Bold"
                                            Command="{Binding DongOverlayCommand}"/>
                                </Grid>
                            </Border>

                            <!-- TabControl: SelectedIndex bind vào ActiveOverlayTab -->
                            <TabControl Grid.Row="1"
                                        SelectedIndex="{Binding ActiveOverlayTab, Mode=TwoWay}"
                                        BorderThickness="0" Background="White">

                                <!-- ===== TAB 0: KHÁCH HÀNG ===== -->
                                <TabItem Header="👤  Khách hàng" FontSize="13" FontWeight="SemiBold">
                                    <Grid Margin="40,20">
                                        <StackPanel MaxWidth="500" HorizontalAlignment="Center" VerticalAlignment="Center">

                                            <TextBlock Text="Nhập số điện thoại để tìm khách hàng cũ"
                                                       FontSize="13" Foreground="#777"
                                                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

                                            <!-- SĐT -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Số điện thoại:"
                                                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                <TextBox Grid.Column="1" Height="34" Padding="8,4" FontSize="13"
                                                         Text="{Binding DatBan_SDT, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>

                                            <!-- Thông báo tìm KH -->
                                            <Border Background="#F0F4FF" CornerRadius="6" Padding="10,6" Margin="0,0,0,12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ThongBaoTimKH}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding ThongBaoTimKH}"
                                                           FontSize="12" TextWrapping="Wrap"/>
                                            </Border>

                                            <!-- Họ tên -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Họ và tên:"
                                                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                <TextBox Grid.Column="1" Height="34" Padding="8,4" FontSize="13"
                                                         Text="{Binding DatBan_TenKH, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>

                                            <!-- Điểm tích lũy -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Điểm tích lũy:"
                                                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                           Margin="8,0" Foreground="#6a1b9a" FontWeight="Bold"
                                                           Text="{Binding DatBan_DiemTichLuy, StringFormat={}{0} điểm}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </TabItem>

                                <!-- ===== TAB 1: ĐẶT MÓN ===== -->
                                <TabItem Header="🍽️  Đặt món" FontSize="13" FontWeight="SemiBold">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="265"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Danh sách sản phẩm -->
                                        <Border Grid.Column="0" BorderBrush="#E0E0E0"
                                                BorderThickness="0,0,1,0" Padding="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="📦 Sản phẩm" FontWeight="Bold"
                                                           FontSize="13" Margin="0,0,0,6"/>
                                                <ListBox Grid.Row="1"
                                                         ItemsSource="{Binding DsSanPham}"
                                                         SelectedItem="{Binding SelectedSanPham, Mode=TwoWay}"
                                                         BorderThickness="1" BorderBrush="#E0E0E0">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="4,4" Cursor="Hand">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Ten}"
                                                                               FontWeight="SemiBold" FontSize="12"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding Ma}"
                                                                               FontSize="10" Foreground="Gray"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="1"
                                                                           FontWeight="Bold" FontSize="12"
                                                                           Foreground="#2e7d32"
                                                                           VerticalAlignment="Top"
                                                                           Margin="6,1,0,0">
                                                                    <TextBlock.Text>
                                                                        <Binding Path="DonGia" StringFormat="{}{0:N0}đ"/>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Grid>
                                        </Border>

                                        <!-- Chi tiết + số lượng + nút thêm -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">

                                            <TextBlock FontSize="15" FontWeight="Bold"
                                                       HorizontalAlignment="Center" Margin="0,0,0,10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="— Chọn sản phẩm —"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Đơn giá: " FontSize="13"/>
                                                <TextBlock FontSize="13" Foreground="#2e7d32" FontWeight="Bold"
                                                           Text="{Binding SelectedSanPham.DonGia,
                                                                  StringFormat={}{0:N0} đ,
                                                                  TargetNullValue=---}"/>
                                            </StackPanel>

                                            <Separator Margin="0,10"/>

                                            <TextBlock Text="Số lượng:" FontSize="13"
                                                       FontWeight="SemiBold" Margin="0,0,0,8"
                                                       HorizontalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="−" Width="36" Height="36"
                                                        Background="#EEEEEE" BorderBrush="#CCC"
                                                        FontSize="20" FontWeight="Bold"
                                                        VerticalContentAlignment="Center"
                                                        Command="{Binding GiamSoLuongCommand}"/>
                                                <TextBox Width="54" Height="36" Margin="6,0"
                                                         TextAlignment="Center" FontSize="15" FontWeight="Bold"
                                                         VerticalContentAlignment="Center"
                                                         Text="{Binding SoLuongDat, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Button Content="+" Width="36" Height="36"
                                                        Background="#EEEEEE" BorderBrush="#CCC"
                                                        FontSize="20" FontWeight="Bold"
                                                        VerticalContentAlignment="Center"
                                                        Command="{Binding TangSoLuongCommand}"/>
                                            </StackPanel>

                                            <Button Content="＋  Thêm vào đơn"
                                                    Height="38" Margin="0,16,0,0"
                                                    Style="{StaticResource OverlayBtnStyle}"
                                                    Background="#1565C0" Padding="20,0"
                                                    Command="{Binding ThemMonCommand}"/>
                                        </StackPanel>

                                        <!-- Đơn hàng -->
                                        <Border Grid.Column="2" BorderBrush="#E0E0E0"
                                                BorderThickness="1,0,0,0" Padding="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Text="🧾 Đơn hàng"
                                                           FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>

                                                <ListView Grid.Row="1"
                                                          ItemsSource="{Binding DsDatMon}"
                                                          SelectedItem="{Binding SelectedDatMon, Mode=TwoWay}"
                                                          BorderThickness="1" BorderBrush="#E0E0E0">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="Tên món" Width="105"
                                                                            DisplayMemberBinding="{Binding TenMon}"/>
                                                            <GridViewColumn Header="SL" Width="28"
                                                                            DisplayMemberBinding="{Binding SoLuong}"/>
                                                            <GridViewColumn Header="T.Tiền" Width="75">
                                                                <GridViewColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock FontSize="11" TextAlignment="Right"
                                                                                   Text="{Binding ThanhTien, StringFormat={}{0:N0}đ}"/>
                                                                    </DataTemplate>
                                                                </GridViewColumn.CellTemplate>
                                                            </GridViewColumn>
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>

                                                <TextBlock Grid.Row="2" HorizontalAlignment="Right"
                                                           Margin="0,6" FontWeight="Bold" FontSize="13">
                                                    <Run Text="Tổng: "/>
                                                    <Run Foreground="Red"
                                                         Text="{Binding TongTienDatMon, StringFormat={}{0:N0} đ}"/>
                                                </TextBlock>

                                                <Button Grid.Row="3" Content="🗑️  Xóa món đã chọn"
                                                        Height="34" Style="{StaticResource OverlayBtnStyle}"
                                                        Background="#c62828" Padding="0"
                                                        Command="{Binding XoaMonCommand}"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </TabItem>
                            </TabControl>

                            <!-- Footer -->
                            <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                                <Grid Margin="20,0">
                                    <!-- Tóm tắt đơn -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Số món: " FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding DsDatMon.Count}"
                                                   Foreground="#1565C0" FontWeight="Bold"
                                                   FontSize="13" Margin="0,0,16,0"/>
                                        <TextBlock Text="Tổng tạm: " FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Foreground="Red" FontWeight="Bold" FontSize="13"
                                                   Text="{Binding TongTienDatMon, StringFormat={}{0:N0} VNĐ}"/>
                                    </StackPanel>
                                    <!-- Nút Hủy + Xác nhận -->
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Content="Hủy" Width="90" Height="36" Margin="0,0,10,0"
                                                Style="{StaticResource OverlayBtnStyle}"
                                                Background="#9E9E9E" Padding="0"
                                                Command="{Binding DongOverlayCommand}"/>
                                        <Button Content="✅  Xác nhận đặt bàn"
                                                Height="36" Padding="18,0"
                                                Style="{StaticResource OverlayBtnStyle}"
                                                Background="#2e7d32"
                                                Command="{Binding XacNhanDatMonCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </Grid>
                    </Border>
                </Grid>
                <!-- ===== KẾT THÚC OVERLAY ===== -->

            </Grid>
        </Border>
    </Grid>
</UserControl>
