<UserControl x:Class="QuanLyQuanBida.Views.BanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyQuanBida.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="734" d:DesignWidth="1150"
             d:DataContext="{d:DesignInstance local:MainViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <Style x:Key="TrangThaiColorStyle" TargetType="Border">
            <Setter Property="Background" Value="#047b5c"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding TrangThaiBan}" Value="True">
                    <Setter Property="Background" Value="Green"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="#FF9800"/>
                    <Setter Property="BorderThickness" Value="4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="BanLoTemplate">
            <Border Width="140" Height="90" Style="{StaticResource TrangThaiColorStyle}" CornerRadius="8" Margin="10">
                <Grid>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-2"/>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="-2"/>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-2"/>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-2"/>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="-2"/>
                    <Ellipse Fill="White" Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="-2"/>
                    <TextBlock Text="{Binding TenBan}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="BanPhangTemplate">
            <Border Width="140" Height="90" Background="#118cbe" Style="{StaticResource TrangThaiColorStyle}" CornerRadius="8" Margin="10">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,5">
                        <Ellipse Fill="White" Width="10" Height="10" Margin="2"/>
                        <Ellipse Fill="Yellow" Width="10" Height="10" Margin="2"/>
                        <Ellipse Fill="Red" Width="10" Height="10" Margin="2"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TenBan}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="#FFE9E9E9">
        <Grid.RowDefinitions>
            <RowDefinition Height="68*"/>
            <RowDefinition Height="299*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#FFF2EDC2" BorderThickness="1" Margin="30,20,30,0" Background="White" CornerRadius="20,20,20,20">
            <Grid>
                <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="BÀN" VerticalAlignment="Center" FontWeight="Bold" FontSize="36" Foreground="Black" Margin="40,0,0,0"/>
                <Button Content="❌" Background="{x:Null}" FontWeight="Bold" FontSize="40" Foreground="Black" Margin="985,26,44,33" BorderBrush="{x:Null}" Click="Button_Click"/>
                <TextBlock Text="{Binding CurrentAccount.TenNV}" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center" FontWeight="Bold" FontSize="20" Foreground="Black" Margin="797,0,0,0"/>
            </Grid>
        </Border>

        <Border BorderBrush="#FFF2EDC2" BorderThickness="1" Grid.Row="1" Margin="30,20,30,20" Background="White" CornerRadius="20,20,20,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Lọc bàn: " VerticalAlignment="Center" FontWeight="Bold"/>
                        <ComboBox Width="150" Margin="10,0,0,0">
                            <ComboBoxItem Content="Tất cả"/>
                            <ComboBoxItem Content="Bàn trống"/>
                            <ComboBoxItem Content="Có khách"/>
                        </ComboBox>
                    </StackPanel>

                    <ScrollViewer x:Name="TrangHienThiBan" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding DsBan}" 
                                 SelectedItem="{Binding SelectedBan, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding}">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding KieuBan}" Value="BanLoTemple">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource BanLoTemplate}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding KieuBan}" Value="BanPhangTemple">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource BanPhangTemplate}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>

                <Rectangle Grid.Column="0" HorizontalAlignment="Right" Width="1" Fill="Black" Margin="0,10,0,10"/>

                <Grid Grid.Column="1" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="CHI TIẾT HÓA ĐƠN" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Tên bàn: " FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedBan.TenBan}" Margin="5,0,0,0" FontWeight="Bold" Foreground="Blue"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Trạng thái: " FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedBan.TrangThaiBan}" Foreground="Gray" Margin="5,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Giờ chơi: " FontWeight="SemiBold"></TextBlock>
                            <TextBlock Text="(Binding HoaDon)" Foreground="Gray" Margin="5,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <ListView Grid.Row="1" Margin="0,10,0,10" BorderBrush="#FFCCCCCC" BorderThickness="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Tên món" Width="140"/>
                                <GridViewColumn Header="Số lượng" Width="80"/>
                                <GridViewColumn Header="Thành tiền" Width="100"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                            <TextBlock Text="Tổng tiền: " FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="0 VNĐ" FontWeight="Bold" FontSize="16" Foreground="Red" Margin="5,0,10,0"/>
                        </StackPanel>

                        <Button x:Name="btt_DatBan" Content="Đặt Bàn" Margin="0,0,0,5" Height="35" Background="Green" Foreground="White" FontWeight="Bold"/>
                        <Button x:Name="btt_XuatHoaDon" Content="Xuất Hóa Đơn" Margin="0,0,0,5" Height="35" Background="IndianRed" Foreground="White" FontWeight="Bold"/>
                        <Button x:Name="btt_ThanhToan" Content="Thanh toán" Height="35" Background="OrangeRed" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>